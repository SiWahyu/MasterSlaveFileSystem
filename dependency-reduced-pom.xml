<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
  <modelVersion>4.0.0</modelVersion>
  <groupId>org.example</groupId>
  <artifactId>MasterSlaveFileSystem</artifactId>
  <version>1.0-SNAPSHOT</version>
  <build>
    <plugins>
      <plugin>
        <artifactId>maven-shade-plugin</artifactId>
        <version>3.4.1</version>
        <executions>
          <execution>
            <id>shade-master</id>
            <phase>package</phase>
            <goals>
              <goal>shade</goal>
            </goals>
            <configuration>
              <shadedArtifactAttached>true</shadedArtifactAttached>
              <shadedClassifierName>master</shadedClassifierName>
              <transformers>
                <transformer>
                  <mainClass>com.masterslave.MasterApplication</mainClass>
                </transformer>
              </transformers>
            </configuration>
          </execution>
          <execution>
            <id>shade-slave</id>
            <phase>package</phase>
            <goals>
              <goal>shade</goal>
            </goals>
            <configuration>
              <shadedArtifactAttached>true</shadedArtifactAttached>
              <shadedClassifierName>slave</shadedClassifierName>
              <transformers>
                <transformer>
                  <mainClass>com.masterslave.SlaveApplication</mainClass>
                </transformer>
              </transformers>
            </configuration>
          </execution>
        </executions>
      </plugin>
      <plugin>
        <groupId>com.akathist.maven.plugins.launch4j</groupId>
        <artifactId>launch4j-maven-plugin</artifactId>
        <version>2.4.1</version>
        <executions>
          <execution>
            <id>l4j-master</id>
            <phase>package</phase>
            <goals>
              <goal>launch4j</goal>
            </goals>
            <configuration>
              <headerType>gui</headerType>
              <outfile>${project.build.directory}/MasterServer.exe</outfile>
              <jar>${project.build.directory}/${project.build.finalName}-master.jar</jar>
              <errTitle>App Err</errTitle>
              <classPath>
                <mainClass>com.masterslave.MasterApplication</mainClass>
              </classPath>
              <jre>
                <minVersion>17</minVersion>
                <path>%JAVA_HOME%</path>
              </jre>
            </configuration>
          </execution>
          <execution>
            <id>l4j-slave</id>
            <phase>package</phase>
            <goals>
              <goal>launch4j</goal>
            </goals>
            <configuration>
              <headerType>gui</headerType>
              <outfile>${project.build.directory}/SlaveClient.exe</outfile>
              <jar>${project.build.directory}/${project.build.finalName}-slave.jar</jar>
              <errTitle>App Err</errTitle>
              <classPath>
                <mainClass>com.masterslave.SlaveApplication</mainClass>
              </classPath>
              <jre>
                <minVersion>17</minVersion>
                <path>%JAVA_HOME%</path>
              </jre>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>
  <properties>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <maven.compiler.target>17</maven.compiler.target>
    <maven.compiler.source>17</maven.compiler.source>
  </properties>
</project>
